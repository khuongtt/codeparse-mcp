{
  "name": "codeparse-mcp",
  "version": "2.5.0",
  "description": "Code Parser MCP Tool — Java/Xtend AST+CFG to Graph DB for ISO 26262 ASIL-D UT generation with evidence export",
  "type": "module",
  "bin": {
    "codeparse": "./src/cli/index.js"
  },
  "scripts": {
    "start": "node src/mcp/server.js",
    "cli": "node src/cli/index.js",
    "dev": "node --watch src/mcp/server.js",
    "test": "node --test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^9.6.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "crypto": "^1.0.1",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.9.3",
    "glob": "^11.0.0",
    "java-parser": "^2.3.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-cpp": "^0.23.4"
  },
  "engines": {
    "node": ">=20"
  },
  "allowScripts": {
    "better-sqlite3@9.6.0": true
  }
}
